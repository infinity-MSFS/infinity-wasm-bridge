{
  "name": "@infinity-msfs/rescript-instrument",
  "version": "0.1.0",
  "description": "ReScript bindings for registering MSFS BaseInstrument subclasses.",
  "license": "MIT",
  "author": "cameron_griego@protonmail.com",
  "homepage": "https://github.com/infinity-MSFS/infinity-wasm-bridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infinity-MSFS/infinity-wasm-bridge.git",
    "directory": "rescript/infinity-instrument"
  },
  "bugs": {
    "url": "https://github.com/infinity-MSFS/infinity-wasm-bridge/issues"
  },
  "keywords": [
    "msfs",
    "flightsim",
    "rescript",
    "instrument",
    "baseinstrument",
    "gauge"
  ],
  "type": "module",
  "files": [
    "src/**/*.res",
    "src/**/*.resi",
    "src/**/*.res.mjs",
    "src/**/*.mjs",
    "rescript.json"
  ],
  "exports": {
    ".": {
      "import": "./src/Instrument.res.mjs"
    },
    "./shell": {
      "import": "./src/instrumentShell.mjs"
    },
    "./src/*.res.mjs": "./src/*.res.mjs",
    "./src/*.mjs": "./src/*.mjs"
  },
  "scripts": {
    "build": "rescript",
    "clean": "rescript clean",
    "watch": "rescript -w"
  },
  "peerDependencies": {
    "rescript": "^11.1.0"
  },
  "devDependencies": {
    "@rescript/core": "^1.6.1",
    "rescript": "^11.1.4"
  }
}